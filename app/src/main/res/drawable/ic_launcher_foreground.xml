<?xml version="1.0" encoding="utf-8"?>
<!--
    Dumbbell / barbell icon for the app launcher.
    The icon is drawn within a 108×108 dp viewport (standard adaptive-icon size).
    Extra padding on all sides keeps the dumbbell visibly smaller than the full safe zone,
    as requested (issue #6).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Dumbbell centered in the viewport.
        Left plate: x 20–30, Right plate: x 78–88, Bar: y 50–58
        Top/bottom collars are implied by the plate rectangles.
    -->

    <!-- Left outer plate -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M20,40 L30,40 L30,68 L20,68 Z" />

    <!-- Left inner collar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,46 L38,46 L38,62 L30,62 Z" />

    <!-- Bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,51 L70,51 L70,57 L38,57 Z" />

    <!-- Right inner collar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M70,46 L78,46 L78,62 L70,62 Z" />

    <!-- Right outer plate -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M78,40 L88,40 L88,68 L78,68 Z" />

</vector>
